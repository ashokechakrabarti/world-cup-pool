# ─── Required ───────────────────────────────────────────────────────────────

# Postgres connection string (Neon, Vercel Postgres, Supabase, etc.).
# Include ?sslmode=require for hosted databases.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── Recommended ────────────────────────────────────────────────────────────

# Free token from https://www.football-data.org/client/register (server-side only).
# Powers automatic results sync. Without it, enter results by hand in the Commissioner tab.
FOOTBALL_DATA_TOKEN=

# ─── Optional ───────────────────────────────────────────────────────────────

# Anthropic API key from https://console.anthropic.com — powers the AI commentary booth.
# When unset, the booth is simply disabled; everything else works.
ANTHROPIC_API_KEY=

# Free key from https://the-odds-api.com — powers the daily over/under lines.
# When unset, the daily over/under add-on falls back to a fixed 2.5 line.
ODDS_API_KEY=

# Default pool payee, used to seed config on first run; editable in the Commissioner tab.
# Leave blank to set it in the UI instead.
POOL_VENMO_HANDLE=

# Protects the /api/cron/sync endpoint if you enable Vercel Cron. Any random string.
CRON_SECRET=

# Set ONLY if you serve the app under a sub-path (e.g. /worldcup2026). Leave unset for the
# domain root. If you set it, also prefix the cron path in vercel.json to match.
# BASE_PATH=/worldcup2026

# Set to "disable" only for a local non-SSL Postgres.
# PGSSL=disable
